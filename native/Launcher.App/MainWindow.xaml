<Window x:Class="Launcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Launcher Native (Phase 1)" Height="780" Width="1180" MinHeight="660" MinWidth="1020"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#0C0F17">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="16" Padding="14" CornerRadius="10" Background="#121A2A" BorderBrush="#2A3652" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Launcher Native Desktop" FontSize="22" FontWeight="SemiBold" Foreground="#DCE6FF" />
                    <TextBlock Margin="0,4,0,0" Text="Phase 1 bridge: run existing launcher.ps1 with Start/Close modes while native migration is underway." Foreground="#8FA8D8" TextWrapping="Wrap" />
                    <TextBlock x:Name="StatusText" Margin="0,8,0,0" Text="Ready" Foreground="#8CE0A1" FontWeight="SemiBold" />
                </StackPanel>
                <CheckBox x:Name="DryRunCheckBox" Grid.Column="1" Margin="12,4,0,0" Content="Dry Run" IsChecked="True" Foreground="#DCE6FF" VerticalAlignment="Top" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,0,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Padding="12" CornerRadius="10" Background="#121A2A" BorderBrush="#2A3652" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Launcher Config" Foreground="#DCE6FF" FontWeight="SemiBold" />
                    <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
                        <Button x:Name="BrowseConfigButton" Content="Browse" Width="90" Height="30" Margin="8,0,0,0" DockPanel.Dock="Right" Click="BrowseConfigButton_OnClick" />
                        <Button x:Name="ReloadConfigButton" Content="Reload" Width="90" Height="30" Margin="8,0,0,0" DockPanel.Dock="Right" Click="ReloadConfigButton_OnClick" />
                        <TextBox x:Name="ConfigPathTextBox" Height="30" VerticalContentAlignment="Center" Padding="8,0" Background="#0D1422" Foreground="#DCE6FF" BorderBrush="#2A3652" BorderThickness="1" />
                    </DockPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                <Button x:Name="StartButton" Width="220" Height="36" Margin="0,0,0,8" Content="Run Start" Click="StartButton_OnClick" />
                <Button x:Name="CloseButton" Width="220" Height="36" Margin="0,0,0,8" Content="Run Close" Click="CloseButton_OnClick" />
                <Button x:Name="StartAndWaitButton" Width="220" Height="36" Content="Start + Wait For CLOSEAPPS" Click="StartAndWaitButton_OnClick" />
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2" Margin="16,0,16,16" Background="#121A2A" BorderBrush="#2A3652" BorderThickness="1">
            <TabItem Header="Run">
                <Grid Margin="12" Background="#121A2A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,8,0" Padding="10" CornerRadius="10" Background="#101829" BorderBrush="#2A3652" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Configured Steps (Editable Enabled State)" FontWeight="SemiBold" Foreground="#DCE6FF" />

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                                <Button x:Name="DetectRunningButton" Content="Native Detect Running" Width="160" Height="30" Click="DetectRunningButton_OnClick" />
                                <Button x:Name="DetectCloseTargetsButton" Content="Native Detect Close Targets" Width="190" Height="30" Margin="8,0,0,0" Click="DetectCloseTargetsButton_OnClick" />
                            </StackPanel>

                            <DataGrid x:Name="StepsGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      Background="#0D1422" Foreground="#DCE6FF" BorderBrush="#2A3652" BorderThickness="1"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      SelectionMode="Single" SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay}" Width="80" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" IsReadOnly="True" Width="100" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="220" />
                                    <DataGridTextColumn Header="Program" Binding="{Binding ProgramPath}" IsReadOnly="True" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Margin="8,0,0,0" Padding="10" CornerRadius="10" Background="#101829" BorderBrush="#2A3652" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Live Output" FontWeight="SemiBold" Foreground="#DCE6FF" />
                            <ListBox x:Name="LogListBox" Grid.Row="1" Margin="0,8,0,0" Background="#0D1422" Foreground="#BFD2F7" BorderBrush="#2A3652" BorderThickness="1" FontFamily="Consolas" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Margin="12" Background="#121A2A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="12" CornerRadius="10" Background="#101829" BorderBrush="#2A3652" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Global Launcher Settings" FontWeight="SemiBold" Foreground="#DCE6FF" />
                            <WrapPanel Margin="0,8,0,0">
                                <CheckBox x:Name="CheckForUpdatesCheckBox" Content="Check For Updates" Foreground="#DCE6FF" Margin="0,0,18,8" />
                                <CheckBox x:Name="EnsureCapsLockCheckBox" Content="Ensure Caps Lock On" Foreground="#DCE6FF" Margin="0,0,18,8" />
                                <CheckBox x:Name="EnsureNumLockCheckBox" Content="Ensure Num Lock On" Foreground="#DCE6FF" Margin="0,0,18,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Margin="0,10,0,0" Padding="12" CornerRadius="10" Background="#101829" BorderBrush="#2A3652" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Close Tracking" Foreground="#DCE6FF" />
                                <CheckBox x:Name="CloseOnlyTrackedCheckBox" Content="Close Only Tracked Apps" Foreground="#DCE6FF" Margin="0,6,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Default Close Method" Foreground="#DCE6FF" />
                                <ComboBox x:Name="DefaultCloseMethodComboBox" Margin="0,6,0,0" Height="28">
                                    <ComboBoxItem Content="both" />
                                    <ComboBoxItem Content="graceful" />
                                    <ComboBoxItem Content="process" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="Default Timeout (sec)" Foreground="#DCE6FF" />
                                <TextBox x:Name="DefaultCloseTimeoutTextBox" Margin="0,6,0,0" Height="28" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                <TextBlock Text="Default Force Close" Foreground="#DCE6FF" />
                                <CheckBox x:Name="DefaultCloseForceCheckBox" Content="Enabled" Foreground="#DCE6FF" Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Margin="2,10,0,0" Text="Tip: You can toggle individual step enabled states in the Run tab and save all settings together." Foreground="#8FA8D8" />

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="SaveSettingsButton" Width="180" Height="34" Content="Save Config Changes" Click="SaveSettingsButton_OnClick" />
                        <Button x:Name="ResetSettingsButton" Width="180" Height="34" Margin="8,0,0,0" Content="Reload Without Saving" Click="ResetSettingsButton_OnClick" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
