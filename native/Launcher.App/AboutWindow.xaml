<Window x:Class="Launcher.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Launcher Native"
        Height="420"
        Width="560"
        MinHeight="380"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0C0F17">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Launcher Native"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#DCE6FF" />

        <TextBlock x:Name="VersionTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="#8FA8D8"
                   FontSize="13"
                   Text="Version" />

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="12"
                CornerRadius="10"
                BorderBrush="#2A3652"
                BorderThickness="1"
                Background="#101829">
            <StackPanel>
                <TextBlock Foreground="#DCE6FF"
                           FontWeight="SemiBold"
                           Text="About This App" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#BFD2F7"
                           TextWrapping="Wrap"
                           Text="Launcher Native is a desktop control center for your startup workflow. It runs and closes your configured applications through the Launcher script bridge while the native migration continues." />

                <TextBlock Margin="0,16,0,0"
                           Foreground="#DCE6FF"
                           FontWeight="SemiBold"
                           Text="Creator" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#BFD2F7"
                           Text="Judson M. Fitzpatrick, Irish_Coders_Programming" />

                <TextBlock Margin="0,16,0,0"
                           Foreground="#DCE6FF"
                           FontWeight="SemiBold"
                           Text="Copyright" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#BFD2F7"
                           TextWrapping="Wrap"
                           Text="Copyright 2026 Judson M. Fitzpatrick, Irish_Coders_Programming. All rights reserved." />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="3"
                   Margin="0,16,0,0"
                   LastChildFill="False">
            <Button x:Name="CheckUpdatesButton"
                    Width="150"
                    Height="34"
                    Content="Check for Updates"
                    Click="CheckUpdatesButton_OnClick"
                    DockPanel.Dock="Left" />

            <Button x:Name="CloseButton"
                    Width="90"
                    Height="34"
                    Margin="8,0,0,0"
                    Content="Close"
                    Click="CloseButton_OnClick"
                    DockPanel.Dock="Right" />
        </DockPanel>
    </Grid>
</Window>
